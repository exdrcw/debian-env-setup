# Copy this file to config/setup.env and edit it for your machine.

# Leave empty to auto-detect the current user.
TARGET_USER=""

# Grant sudo to TARGET_USER. Set to 1 when running the first bootstrap as root.
GRANT_SUDO=0

# If GRANT_SUDO=1, also create a passwordless sudo rule.
SUDO_NOPASSWD=0

# Install steps
INSTALL_BASE_PACKAGES=1
INSTALL_NODEJS=1
INSTALL_SHELL_TOOLS=1
CONFIGURE_PROXY=1
CHANGE_DEFAULT_SHELL_TO_ZSH=1

# Base packages. Keep this as a space-separated list.
BASE_PACKAGES="curl wget git sudo ca-certificates build-essential zsh tmux unzip zip xz-utils gnupg lsb-release jq ripgrep fd-find"

# Proxy.
# Use an HTTP(S) proxy URL here when possible because apt does not support socks directly.
PROXY_URL="http://127.0.0.1:7890"
HTTP_PROXY="${PROXY_URL}"
HTTPS_PROXY="${PROXY_URL}"
ALL_PROXY=""
NO_PROXY="localhost,127.0.0.1,::1,.local"

# Tool-specific proxy overrides. Leave empty to reuse HTTP_PROXY / HTTPS_PROXY.
APT_HTTP_PROXY=""
APT_HTTPS_PROXY=""
GIT_HTTP_PROXY=""
GIT_HTTPS_PROXY=""
NPM_PROXY=""
NPM_HTTPS_PROXY=""

# Registry / mirrors
NPM_REGISTRY="https://registry.npmjs.org/"

# Git clone sources for shell tooling
OH_MY_ZSH_REPO_URL="https://github.com/ohmyzsh/ohmyzsh.git"
OH_MY_TMUX_REPO_URL="https://github.com/gpakosz/.tmux.git"

